{
  "outputDirectory": "build/web",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:js|css|wasm|mjs|png|jpg|jpeg|gif|svg|ico|json|ttf|woff|woff2)$).*)",
      "destination": "/"
    }
  ]
}
