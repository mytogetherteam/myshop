{
  "installCommand": "if [ ! -d \"$HOME/flutter\" ]; then git clone https://github.com/flutter/flutter.git --depth 1 --branch stable \"$HOME/flutter\"; fi && \"$HOME/flutter/bin/flutter\" --version",
  "buildCommand": "\"$HOME/flutter/bin/flutter\" config --enable-web && \"$HOME/flutter/bin/flutter\" pub get && \"$HOME/flutter/bin/flutter\" build web --release",
  "outputDirectory": "build/web",
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"PWA-Production\" ]; then exit 1; else exit 0; fi",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "integration": false,
      "PWA-1": false
    }
  },
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/flutter_service_worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
